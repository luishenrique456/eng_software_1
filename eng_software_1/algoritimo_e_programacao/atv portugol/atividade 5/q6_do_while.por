programa {
  funcao inicio() {
    // 6) Peça ao usuário para digitar uma letra até que seja informada uma vogal.
    caracter letra
    faca{
      escreva("Digite uma letra : ")
      leia(letra)
    }enquanto(letra != 'a' e letra != 'A' e letra != 'e' e letra != 'E' e letra != 'i' e letra != 'I' e letra != 'o' e letra != 'O' e letra != 'u' e letra != 'U')
    
    
  }
}
