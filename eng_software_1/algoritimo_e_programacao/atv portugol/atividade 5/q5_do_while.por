programa {
  funcao inicio() {
    // 5) Leia números até que o usuário digite um número múltiplo de 7.
    inteiro num
    escreva("programa vai encerrar digita um número múltiplo de 7\n")

    faca{
      escreva("Digite um número : ")
      leia(num)
    }enquanto(num % 7 != 0)
    
    escreva("programa encerrado")




  }
}
